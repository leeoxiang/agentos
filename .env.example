# --- Required for paid x402 endpoints -------------------------------------
# Address that receives x402 payments. Until this is set, every metered
# endpoint answers 402 with a configuration error instead of settling.
NEXT_PUBLIC_PAY_TO=0xYourReceiverAddress

# --- Optional -------------------------------------------------------------
# A funded key that broadcasts transferWithAuthorization on behalf of payers.
# With it, x402 payment is genuinely gasless for the paying agent. Without it,
# the 402 response hands back the exact calldata so the payer can self-submit —
# the signed authorization is identical either way.
# FACILITATOR_PRIVATE_KEY=0x...

# Arms the autonomous trader. Absent, the strategy can only propose; present,
# live mode can be switched on and it broadcasts real swaps.
# TRADER_PRIVATE_KEY=0x...

# Powers the Console agent and the research.brief endpoint. Without it, both
# report themselves offline rather than failing opaquely.
# ANTHROPIC_API_KEY=sk-ant-...

# --- Arena (recommended on Vercel) ----------------------------------------
# Upstash / Vercel KV. The arena's books and feed live here; without them state
# is per-instance and resets on every serverless cold start.
# KV_REST_API_URL=https://...upstash.io
# KV_REST_API_TOKEN=...

# Derives the five arena agents' wallets. The default seed is public, so those
# wallets are unfunded — they sign real authorizations that verify but cannot
# settle. Set your own and fund the addresses to have agents pay for real.
# ARENA_SEED=some-long-random-string

# Bearer token Vercel attaches to scheduled cron requests. Without it,
# GET /api/arena/tick returns 401 and the arena will not advance on its own.
# Generate any long random string.
# CRON_SECRET=
