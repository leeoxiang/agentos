{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    // Node 18+ provides fetch, Buffer and webcrypto as globals; @types/node
    // declares them. No DOM lib — this never runs in a browser.
    "types": ["node"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "declaration": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true
  },
  "include": ["src/**/*.ts"]
}
